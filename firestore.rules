rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Configuración de la app — lectura libre, escritura libre (panel Admin)
    match /config/{doc} {
      allow read, write: if true;
    }

    // Leaderboard Globos — lectura libre, solo agregar (no editar ni borrar)
    match /leaderboard/{doc} {
      allow read:   if true;
      allow create: if true;
      allow update, delete: if false;
    }

    // Leaderboard Space Blaster — misma política
    match /shooter_scores/{doc} {
      allow read:   if true;
      allow create: if true;
      allow update, delete: if false;
    }

    // RSVP — lectura y escritura libres (upsert por nombre)
    match /rsvp/{doc} {
      allow read, write: if true;
    }

    // Galería de fotos — lectura libre, agregar y borrar metadatos, likes
    match /photos/{doc} {
      allow read:   if true;
      allow create: if true;
      allow delete: if true;
      // Solo se permite actualizar el campo 'likes', incrementándolo en +1.
      // resource.data.get('likes', 0) maneja fotos existentes sin el campo.
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes'])
                    && request.resource.data.likes == resource.data.get('likes', 0) + 1;
    }
  }
}
